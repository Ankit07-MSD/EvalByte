PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/evalbyte
JWT_SECRET=change-this-to-a-long-random-secret

# Code execution (pick one)
# Free (default): self-hosted Piston — run from Evalbyte folder:
#   docker compose -f docker-compose.piston.yml up -d
CODE_RUNNER=piston
PISTON_API_BASE=http://127.0.0.1:2000

# Paid / optional: Judge0 on RapidAPI (set CODE_RUNNER=judge0)
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your-rapidapi-key
# JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Allow your Vite dev server
CLIENT_ORIGIN=http://localhost:5173
